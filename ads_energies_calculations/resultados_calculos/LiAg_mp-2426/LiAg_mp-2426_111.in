&CONTROL
calculation = 'relax' ,
restart_mode = 'restart' ,
outdir = './LiAg_111' ,
pseudo_dir = '/home/ecastro/trabajo_final/pseudos/' ,
prefix = 'LiAg_111' ,
max_seconds = 3550 ,
nstep = 500 ,
tstress = .true. ,
tprnfor = .true. ,
 /
&SYSTEM
ibrav = 0,
nat = 6,
ntyp = 2,
ecutwfc = 55 ,
ecutrho = 500 ,
occupations = 'smearing'
degauss = 0.03,
smearing = 'methfessel-paxton'
vdw_corr = 'DFT-D3' ,
dftd3_threebody = .false. ,
nosym = .true.,
/
&ELECTRONS
conv_thr = 1.0d-6 ,
mixing_beta = 0.3 ,
diagonalization = 'david' ,
electron_maxstep = 200
 /
&IONS
ion_dynamics = 'bfgs' 
 /
