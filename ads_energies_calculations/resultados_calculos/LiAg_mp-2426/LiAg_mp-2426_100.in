dftd3_threebody = .false. ,
nosym = .true.,
/
&ELECTRONS
conv_thr = 1.0d-6 ,
mixing_beta = 0.3 ,
diagonalization = 'david' ,
electron_maxstep = 200
 /
&IONS
ion_dynamics = 'bfgs' 
 /
