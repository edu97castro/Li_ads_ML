&CONTROL
calculation = 'relax' ,
restart_mode = 'restart' ,
outdir = './LiAg_100' ,
pseudo_dir = '/home/ecastro/trabajo_final/pseudos/' ,
prefix = 'LiAg_100' ,
max_seconds = 3550 ,
nstep = 500 ,
tstress = .true. ,
tprnfor = .true. ,
 /
&SYSTEM
ibrav = 0,
nat = 6,
ntyp = 2,
ecutwfc = 55 ,
ecutrho = 500 ,
occupations = 'smearing'
degauss = 0.03,
smearing = 'methfessel-paxton'
